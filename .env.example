# YouTube Live Chat integration (optional — widget works without these)
# Get an API key at: https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=your_api_key_here

# OAuth2 credentials — from Google Cloud Console → Credentials → OAuth 2.0 Client ID (Desktop app)
OAUTH_CLIENT_ID=your_client_id_here
OAUTH_CLIENT_SECRET=your_client_secret_here

# After running /auth once, copy the refresh token logged in the console here (Railway only)
OAUTH_REFRESH_TOKEN=

# Your Railway deployment URL (leave empty for local dev)
# e.g. https://your-app.railway.app
BASE_URL=

PORT=3002
