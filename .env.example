# YouTube Live Chat integration (optional — widget works without these)
# Get an API key at: https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=your_api_key_here

# Find your live chat ID from a YouTube Live URL:
#   GET https://www.googleapis.com/youtube/v3/videos?part=liveStreamingDetails&id=VIDEO_ID&key=API_KEY
#   → liveStreamingDetails.activeLiveChatId
LIVE_CHAT_ID=your_live_chat_id_here

PORT=3002
